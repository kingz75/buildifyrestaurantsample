{
  "rules": {
    ".read": false,
    ".write": false,
    "categories": {
      ".read": true,
      ".write": "auth != null && root.child('staffMembers').child(auth.uid).child('active').val() === true"
    },
    "menu": {
      ".read": true,
      ".write": "auth != null && root.child('staffMembers').child(auth.uid).child('active').val() === true"
    },
    "orders": {
      ".read": "(auth != null && root.child('staffMembers').child(auth.uid).child('active').val() === true) || (query.orderByChild === 'accessCode' && query.equalTo != null && query.limitToLast != null && query.limitToLast <= 40)",
      ".indexOn": ["accessCode", "table", "timestamp"],
      "$orderId": {
        ".read": "auth != null && root.child('staffMembers').child(auth.uid).child('active').val() === true",
        ".write": "(auth != null && root.child('staffMembers').child(auth.uid).child('active').val() === true) || (newData.exists() && ((!data.exists() && newData.child('id').val() === $orderId && newData.child('accessCode').isString() && newData.child('table').isNumber() && newData.child('status').val() === 'Pending' && newData.child('timestamp').isNumber()) || (data.exists() && newData.child('id').val() === data.child('id').val() && newData.child('accessCode').val() === data.child('accessCode').val() && newData.child('table').val() === data.child('table').val() && newData.child('status').val() === data.child('status').val() && newData.child('timestamp').val() === data.child('timestamp').val())))",
        ".validate": "newData.hasChildren(['id', 'accessCode', 'table', 'status', 'timestamp'])",
        "id": {
          ".validate": "newData.isString() && newData.val() === $orderId"
        },
        "accessCode": {
          ".validate": "newData.isString() && newData.val().matches(/^[A-Za-z0-9_-]{20,}$/)"
        },
        "table": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "items": {
          ".validate": true
        },
        "subtotal": {
          ".validate": "newData.isNumber() || !newData.exists()"
        },
        "total": {
          ".validate": "newData.isNumber() || !newData.exists()"
        },
        "billingBreakdown": {
          ".validate": true
        },
        "billingSettingsSnapshot": {
          ".validate": true
        },
        "specialInstructions": {
          ".validate": "newData.isString() || !newData.exists()"
        },
        "status": {
          ".validate": "newData.isString() && (newData.val() === 'Pending' || newData.val() === 'Confirmed' || newData.val() === 'Preparing' || newData.val() === 'Ready' || newData.val() === 'Served' || newData.val() === 'Completed')"
        },
        "paymentStatus": {
          ".validate": "!newData.exists() || (newData.isString() && (newData.val() === 'Unpaid' || newData.val() === 'Paid'))"
        },
        "paymentMethod": {
          ".validate": "newData.isString() || !newData.exists()"
        },
        "timestamp": {
          ".validate": "newData.isNumber()"
        },
        "type": {
          ".validate": "newData.isString() || !newData.exists()"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "settings": {
      "billing": {
        ".read": true,
        ".write": "auth != null && root.child('staffMembers').child(auth.uid).child('active').val() === true"
      },
      "itemTags": {
        ".read": "auth != null && root.child('staffMembers').child(auth.uid).child('active').val() === true",
        ".write": "auth != null && root.child('staffMembers').child(auth.uid).child('active').val() === true"
      },
      "$other": {
        ".read": false,
        ".write": false
      }
    },
    "staffMembers": {
      ".read": false,
      ".write": false,
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": false
      }
    },
    "tables": {
      ".read": "auth != null && root.child('staffMembers').child(auth.uid).child('active').val() === true",
      ".write": "auth != null && root.child('staffMembers').child(auth.uid).child('active').val() === true"
    }
  }
}
